{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "noEmit": false
  },
  "include": ["server.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "src/**/*.tsx", "src/main.tsx"]
}
